{
  "name": "agentchattr-desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:terminals && npm run build:bridge",
    "build:terminals": "esbuild renderer/terminals.js --bundle --outfile=renderer/terminals.bundle.js --format=iife --platform=browser",
    "build:bridge": "esbuild renderer/bridge/index.jsx --bundle --outfile=renderer/bridge.bundle.js --format=iife --platform=browser --jsx=automatic --loader:.jsx=jsx",
    "prestart": "npm run build",
    "test": "node --test qa/*.test.cjs",
    "smoke:launcher": "node qa/launcher-smoke.cjs",
    "smoke:desktop": "node qa/desktop-smoke.cjs",
    "smoke:terminal": "node qa/terminal-smoke.cjs"
  },
  "dependencies": {
    "@sakun/system.css": "^0.1.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "98.css": "^0.1.21",
    "electron": "^35.0.0",
    "electron-store": "^8.2.0",
    "nes.css": "^2.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "playwright-core": "^1.59.1"
  }
}
